{
  "name": "t3",
  "private": false,
  "bin": {
    "t3": "apps/t3/dist/cli.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run build:contracts && bun run --cwd apps/t3 dev",
    "build": "bun run build:contracts && bun run --cwd apps/renderer build && bun run --cwd apps/t3 build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "fmt": "oxfmt",
    "build:contracts": "bun run --cwd packages/contracts build"
  },
  "devDependencies": {
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "bun": ">=1.3.9"
  },
  "packageManager": "bun@1.3.9"
}
