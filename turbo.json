{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "HOST",
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "DH_LOG_WS_EVENTS",
    "DH_MODE",
    "DH_PORT",
    "DH_NO_BROWSER",
    "DH_HOME",
    "DH_AUTH_TOKEN",
    "DH_TRACE_MIN_LEVEL",
    "DH_TRACE_TIMING_ENABLED",
    "DH_TRACE_FILE",
    "DH_TRACE_MAX_BYTES",
    "DH_TRACE_MAX_FILES",
    "DH_TRACE_BATCH_WINDOW_MS",
    "DH_OTLP_TRACES_URL",
    "DH_OTLP_METRICS_URL",
    "DH_OTLP_EXPORT_INTERVAL_MS",
    "DH_OTLP_SERVICE_NAME"
  ],
  "globalPassThroughEnv": ["PATHEXT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "dependsOn": ["@dh/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
